{
  "name": "@fulcrumapp/expressions",
  "version": "3.0.0",
  "description": "Expression runtime for Fulcrum",
  "author": "Fulcrum",
  "license": "BSD-3-Clause",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fulcrumapp/fulcrum-expressions.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsdown && node -e \"const fs=require('fs'),p=require('path'),d='dist';fs.readdirSync(d).forEach(f=>{if(/\\.d\\.[cm]?ts$/.test(f)&&/-/.test(f)){const n=f.replace(/-[^.]+/,'');fs.renameSync(p.join(d,f),p.join(d,n))}if(/\\.d\\.[cm]?ts\\.map$/.test(f)&&/-/.test(f)){const n=f.replace(/-[^.]+/,'');fs.renameSync(p.join(d,f),p.join(d,n))}})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@turf/along": "^7.2.0",
    "@turf/area": "^7.2.0",
    "@turf/bearing": "^7.2.0",
    "@turf/boolean-intersects": "^7.2.0",
    "@turf/boolean-within": "^7.2.0",
    "@turf/buffer": "^7.2.0",
    "@turf/centroid": "^7.2.0",
    "@turf/convex": "^7.2.0",
    "@turf/distance": "^7.2.0",
    "@turf/helpers": "^7.2.0",
    "@turf/length": "^7.2.0",
    "@turf/nearest-point": "^7.2.0",
    "@turf/nearest-point-on-line": "^7.2.0",
    "@turf/tag": "^7.2.0",
    "encodeurl": "^2.0.0",
    "lodash": "^4.17.21",
    "object-inspect": "^1.13.4",
    "query-string": "^9.1.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.16",
    "tsdown": "^0.12.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
